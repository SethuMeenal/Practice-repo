    {
      "cell_type": "markdown",
      "source": [
        "TASK-1- Basic Grouping and Single Aggregations"
      ],
      "metadata": {
        "id": "aZzkGe_NaLe1"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "print(\"Sum of sales per region\")\n",
        "print(df.groupby('region')['sales_amount'].sum().reset_index())\n",
        "print(\"Count of transactions per category\")\n",
        "print(df.groupby('category')['transaction_id'].count().reset_index())\n",
        "print(\"Average of sales per salesperson\")\n",
        "print(df.groupby('salesperson')['sales_amount'].mean().reset_index())\n",
        "print(\"Sales per region from high to low\")\n",
        "print(df.groupby('region')['sales_amount'].sum().sort_values(ascending=False))\n"
      ],
      "metadata": {
