    {
      "cell_type": "markdown",
      "source": [
        "TASK-2-Multi-Column Grouping and Multiple Aggregations"
      ],
      "metadata": {
        "id": "B0LPVupHaRnt"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "print(\"Sales per region&category in clean df\")\n",
        "print(df.groupby(['region', 'category'])['sales_amount'].sum().reset_index())\n",
        "print(\"Sum,Avg and Count of sales per salesperson\")\n",
        "print(df.groupby('salesperson')['sales_amount'].agg(['sum', 'mean', 'count']).reset_index())\n",
        "print(\"Salesperson wise sales from high to low\")\n",
        "print(df.groupby('salesperson')['sales_amount'].sum().sort_values(ascending=False))\n",
        "print(\"Maximum selling category\")\n",
        "print(df.groupby('category')['sales_amount'].sum().idxmax())"
      ],
